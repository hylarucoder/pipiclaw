{
  "name": "pipiclaw",
  "version": "1.0.0",
  "description": "An Electron application with React and TypeScript",
  "license": "MIT",
  "main": "./dist/desktop/main/index.cjs",
  "author": "example.com",
  "homepage": "https://github.com/lucasay/pipiclaw",
  "scripts": {
    "format": "prettier --write .",
    "format:ox": "oxfmt -c .oxfmtrc.json --check .",
    "format:ox:write": "oxfmt -c .oxfmtrc.json .",
    "lint": "oxlint -c .oxlintrc.json apps packages scripts",
    "build:packages": "pnpm --filter @pipiclaw/shared run build && pnpm --filter @pipiclaw/agent-core run build",
    "build:desktop": "pnpm --filter @pipiclaw/desktop run build",
    "build:renderer": "pnpm --filter @pipiclaw/renderer run build",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck:monorepo": "pnpm run check:boundaries && pnpm run guard:webui-source && pnpm run guard:no-legacy-webui && tsc --noEmit -p tsconfig.monorepo.json --composite false",
    "typecheck": "pnpm run typecheck:node && pnpm run typecheck:web",
    "check:boundaries": "node scripts/check-boundaries.mjs",
    "guard:webui-source": "node scripts/guard-webui-source.mjs",
    "guard:no-legacy-webui": "node scripts/guard-no-legacy-webui.mjs",
    "test": "vitest run",
    "test:e2e": "pnpm run build && playwright test",
    "test:e2e:headed": "pnpm run build && playwright test --headed",
    "start": "electron .",
    "dev": "node scripts/dev-electron.mjs",
    "build": "pnpm run build:packages && pnpm run typecheck && pnpm run build:renderer && pnpm run build:desktop",
    "metrics:lit": "node scripts/metrics/lit-migration-report.mjs",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "pnpm run build && electron-builder --dir",
    "build:win": "pnpm run build && electron-builder --win",
    "build:mac": "pnpm run build && electron-builder --mac",
    "build:linux": "pnpm run build && electron-builder --linux"
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.34",
    "@base-ui/react": "^1.2.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@excalidraw/excalidraw": "^0.18.0",
    "@fontsource-variable/inter": "^5.2.8",
    "@hookform/resolvers": "^5.2.2",
    "@lit/reactive-element": "^2.1.2",
    "@lmstudio/sdk": "^1.5.0",
    "@mariozechner/pi-agent-core": "^0.55.3",
    "@mariozechner/pi-ai": "^0.55.3",
    "@orpc/client": "^1.13.5",
    "@orpc/server": "^1.13.5",
    "@orpc/zod": "^1.13.5",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@shikijs/rehype": "^3.14.0",
    "@xyflow/react": "^12.10.1",
    "ai": "^6.0.105",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "docx-preview": "^0.3.7",
    "electron-updater": "^6.3.9",
    "embla-carousel-react": "^8.6.0",
    "highlight.js": "^11.11.1",
    "i18next": "^25.6.3",
    "immer": "^10.1.1",
    "input-otp": "^1.4.2",
    "jszip": "^3.10.1",
    "lit-html": "^3.3.2",
    "lucide": "^0.544.0",
    "lucide-react": "^0.575.0",
    "lz-string": "^1.5.0",
    "next-themes": "^0.4.6",
    "ollama": "^0.6.3",
    "pdfjs-dist": "5.4.394",
    "radix-ui": "^1.4.3",
    "react-day-picker": "^9.14.0",
    "react-hook-form": "^7.71.2",
    "react-resizable-panels": "^4.6.5",
    "react-router-dom": "^7.13.1",
    "recharts": "2.15.4",
    "rehype-raw": "^7.0.0",
    "rehype-react": "^8.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "shadcn": "^3.8.5",
    "shiki": "^3.14.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "unified": "^11.0.5",
    "vaul": "^1.1.2",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz",
    "zod": "^4.3.6",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.19.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "electron": "^39.2.6",
    "electron-builder": "^26.0.12",
    "jsdom": "^28.1.0",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0",
    "prettier": "^3.7.4",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-i18next": "^16.2.4",
    "tailwindcss": "^4.2.1",
    "tsdown": "^0.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vite": "^7.2.6",
    "vitest": "^3.2.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "electron-winstaller",
      "esbuild"
    ]
  }
}
