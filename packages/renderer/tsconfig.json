{
  "extends": "@electron-toolkit/tsconfig/tsconfig.web.json",
  "include": [
    "src/env.d.ts",
    "src/**/*",
    "src/**/*.tsx",
    "../../apps/desktop/src/preload/*.d.ts"
  ],
  "compilerOptions": {
    "composite": true,
    "jsx": "react-jsx",
    "experimentalDecorators": true,
    "baseUrl": "../..",
    "paths": {
      "@renderer/*": [
        "packages/renderer/src/*"
      ]
    }
  },
  "references": [{ "path": "../shared" }, { "path": "../agent-core" }]
}
